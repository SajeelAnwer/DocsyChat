# =============================================
# DocsyChat v4.5 — Environment Configuration
# =============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── AI Provider ──────────────────────────────
# "gemini" (default) or "openai"
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Supabase (Database) ───────────────────────
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Anon/Public key from: Supabase Dashboard → Settings → API
SUPABASE_ANON_KEY=your_supabase_anon_public_key
# Password set when creating the Supabase project
SUPABASE_DB_PASSWORD=your_supabase_db_password

# ── JWT Auth ──────────────────────────────────
# Use a long random string — generate at https://randomkeygen.com
# IMPORTANT: Change this before any deployment. Keep it secret.
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── Email (Gmail SMTP) ────────────────────────
# Gmail address used to send verification and password reset emails
EMAIL_FROM=your_gmail@gmail.com
# Gmail App Password (NOT your regular Gmail password)
# Get it: Google Account → Security → 2-Step Verification ON → App Passwords
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Server ────────────────────────────────────
PORT=5000
MAX_FILE_SIZE_MB=10

# ── RAG Settings ─────────────────────────────
RAG_TOP_K=10
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=100
RAG_MIN_SIMILARITY=0.35
